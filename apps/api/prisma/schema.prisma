// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output = "../node_modules/@prisma/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  first_name String
  last_name String
  email String @unique
  password String
  address Address[]
  phone  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}

model Address {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  street String
  user_phone Int?
  apartment String?
  city String?  
  pinCode Int?
  state String?
  defaultAddress Boolean?
  user    User    @relation(fields: [userId], references: [id])
  userId  String  @db.ObjectId
  @@index([userId])
  @@map("addresses")
}

model Products {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  code String
  name String
  stock Json
  price Json
  images Json
  categories Json
  pk String
  whitePrice Json
  articles Json
  visible Boolean
  numberOfPieces Int?
  defaultArticle Json
  sale Boolean
  variantSizes Json
  swatches Json
  articleCodes Json
  ticket String
  searchEngineProductId String
  dummy Boolean
  linkPdp String
  categoryName String
  rgbColors Json
  articleColorNames Json?
  ecoTaxValue Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@map("products")
}

model ProductDetails {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  code String
  name String
  description String
  sapProductName String
  sellingAttributes Json
  color Json
  whitePrice Json
  redPrice Json
  priceType String
  measurements Json
  assortmentsTypeKey String
  lengthCollection Json
  showPriceMarker Boolean
  sapSalesMode String
  baseProductCode String
  ancestorProductCode String
  mainCategory Json
  dynamicHeader String
  supercategories Json
  constructionDescr String
  customerGroup String
  functions Json
  newArrival Boolean
  articlesList Json
  inStock Boolean
  productUrl String
  swatchesType String
  rootCategoryPath String
  productFeature Json
  productKey String
  productCountryOfProduction String
  showGarmentsInfo Boolean
  yearOfProduction String
  complianceMakers Json
  styleCollection Json
  presentationTypes String
  presentationTypesCode String
  multipack Boolean
  newProduct Boolean

  @@map("product_details")
  
}